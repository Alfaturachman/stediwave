# Django Secret Key
# Generate your own with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Django Debug (True for development, False for production)
DEBUG=True

# Database (if using PostgreSQL in production)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Firebase Configuration (path to service account key)
# FIREBASE_CRED_PATH=serviceAccountKey.json
